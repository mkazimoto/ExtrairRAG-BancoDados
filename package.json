{
  "name": "totvs-rm-database-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server para banco de dados ERP TOTVS RM — consulta de esquemas de tabelas e regras de negócio",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env --env-file=dist/.env dist/index.js",
    "start:stdio": "node --env-file=.env --env-file=dist/.env dist/index.js",
    "start:http": "node --env-file=.env --env-file=dist/.env dist/index.js",
    "dev": "tsc --watch",
    "extract": "node --no-warnings=ExperimentalWarning --env-file=.env extract-rag.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.2.1",
    "mssql": "^12.2.1",
    "node-sql-parser": "^5.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
