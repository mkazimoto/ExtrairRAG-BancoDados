{
  "name": "totvs-rm-database-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server para banco de dados ERP TOTVS RM — consulta de esquemas e execução de queries T-SQL",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "extract": "node --no-warnings=ExperimentalWarning extract-rag.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.2.1",
    "mssql": "^12.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
